FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bin/container-hub-agent ./cmd/agent/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/container-hub-agent /usr/local/bin/container-hub-agent
ENTRYPOINT ["container-hub-agent"]
